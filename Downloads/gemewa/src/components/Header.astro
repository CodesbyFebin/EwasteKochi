---
// src/components/Header.astro
// SEO‑optimised header with schema, dark mode, language switcher, and voice search

import { SITE_NAME, SITE_URL, CONTACT_PHONE, CONTACT_PHONE_DISPLAY } from "@/lib/content";

// Keyword‑rich navigation (exact match for high‑intent searches)
const navLinks = [
  { href: '/services', label: 'ITAD Services', keyword: 'ITAD services Kochi' },
  { href: '/sell-electronics-kochi', label: 'Sell Electronics', keyword: 'laptop buyback Kochi' },
  { href: '/hard-drive-destruction-kochi', label: 'Data Destruction', keyword: 'hard drive shredding' },
  { href: '/dpdp-act-kochi', label: 'DPDP Compliance', keyword: 'DPDP Act 2023' },
  { href: '/blog', label: 'Resources', keyword: 'e-waste blog' },
  { href: '/locations', label: 'Service Areas', keyword: 'e-waste pickup Kochi' },
  { href: '/about', label: 'About', keyword: 'certified ITAD Kerala' },
];

// Language options (for hreflang and switcher)
const languages = [
  { code: 'en', label: 'EN', name: 'English', hreflang: 'en', url: '/' },
  { code: 'ml', label: 'മല', name: 'Malayalam', hreflang: 'ml', url: '/ml/' },
  { code: 'ta', label: 'த', name: 'Tamil', hreflang: 'ta', url: '/ta/' },
  { code: 'hi', label: 'हि', name: 'Hindi', hreflang: 'hi', url: '/hi/' },
];

const currentPath = Astro.url.pathname;

// Organization schema (global, but placed here for convenience)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": SITE_NAME,
  "url": SITE_URL,
  "logo": `${SITE_URL}/logo.png`,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": `+91${CONTACT_PHONE}`,
    "contactType": "customer service",
    "areaServed": "IN",
    "availableLanguage": ["English", "Malayalam", "Tamil", "Hindi"]
  },
  "sameAs": [
    "https://www.facebook.com/ewastekochi",
    "https://twitter.com/ewastekochi",
    "https://linkedin.com/company/ewastekochi",
    "https://wa.me/91${CONTACT_PHONE}"
  ]
};

// WebSite schema for search box
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": SITE_URL,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${SITE_URL}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<!-- Inject schemas into document header (they will be merged with any existing) -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<header 
  id="site-header" 
  class="sticky top-0 z-50 bg-white/95 dark:bg-zinc-900/95 backdrop-blur-md border-b border-zinc-200 dark:border-zinc-800 transition-all duration-300"
  itemscope itemtype="https://schema.org/WPHeader"
>
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      
      <!-- Logo with organization schema -->
      <a href="/" class="flex items-center gap-2 group" aria-label={`${SITE_NAME} – Certified ITAD & E‑Waste Recycling Kochi`} itemprop="url">
        <div class="w-10 h-10 bg-green-600 rounded-xl flex items-center justify-center text-white text-xl group-hover:scale-110 transition-transform shadow-lg shadow-green-200 dark:shadow-none">
          ♻️
        </div>
        <div class="flex flex-col leading-none">
          <span class="font-extrabold text-lg text-zinc-900 dark:text-white tracking-tight" itemprop="name">{SITE_NAME}</span>
          <span class="text-[10px] uppercase tracking-[0.15em] text-zinc-500 dark:text-zinc-400 font-semibold">Certified ITAD · Kerala</span>
        </div>
      </a>

      <!-- Desktop Navigation (keyword‑rich) -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="Main navigation">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <a 
              href={link.href} 
              class={`text-sm font-medium transition-colors hover:text-green-600 dark:hover:text-green-400 ${isActive ? 'text-green-600 dark:text-green-400' : 'text-zinc-600 dark:text-zinc-300'}`}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
              <meta itemprop="description" content={link.keyword} />
            </a>
          );
        })}
      </nav>

      <!-- Right side: theme toggle, voice, language, CTA -->
      <div class="flex items-center gap-2 sm:gap-3">
        
        <!-- Dark mode toggle -->
        <button 
          id="theme-toggle" 
          class="p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all"
          aria-label="Switch to dark/light mode"
          title="Dark mode"
        >
          <span class="dark:hidden">🌙</span>
          <span class="hidden dark:inline">☀️</span>
        </button>

        <!-- Voice search button (desktop only) -->
        <button 
          id="voice-search-btn" 
          class="hidden sm:flex p-2 rounded-lg text-zinc-500 hover:text-green-600 hover:bg-green-50 dark:hover:bg-green-950/30 transition-all"
          aria-label="Voice search – speak to find e‑waste services"
          title="Voice search"
        >
          🎤
        </button>

        <!-- Language switcher (desktop) -->
        <div class="hidden md:flex items-center gap-1 border-l border-zinc-200 dark:border-zinc-700 pl-3 ml-1">
          {languages.map(lang => (
            <a 
              href={lang.url} 
              hreflang={lang.hreflang} 
              lang={lang.code}
              class={`px-2 py-1 text-xs font-semibold rounded-md transition-colors ${currentPath === lang.url ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' : 'text-zinc-500 dark:text-zinc-400 hover:text-green-600 dark:hover:text-green-400'}`}
              aria-label={`Switch to ${lang.name}`}
            >
              {lang.label}
            </a>
          ))}
        </div>

        <!-- Phone CTA (with schema) -->
        <a 
          href={`tel:+91${CONTACT_PHONE}`} 
          class="hidden sm:flex items-center gap-1.5 text-sm font-medium text-zinc-600 dark:text-zinc-300 hover:text-green-600 transition-colors"
          aria-label={`Call ${SITE_NAME} at ${CONTACT_PHONE_DISPLAY}`}
        >
          <span>📞</span>
          <span class="hidden lg:inline">{CONTACT_PHONE_DISPLAY}</span>
        </a>

        <!-- WhatsApp CTA (primary) -->
        <a 
          href={`https://wa.me/91${CONTACT_PHONE}?text=Hi%2C%20I%20need%20a%20free%20quote%20for%20e-waste%20disposal`}
          class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-xl transition-all flex items-center gap-2 shadow-md hover:shadow-lg"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get free quote on WhatsApp"
        >
          <span>💬</span>
          <span class="hidden sm:inline">Free Quote</span>
        </a>

        <!-- Mobile menu button -->
        <button 
          id="mobile-menu-toggle" 
          class="md:hidden p-2 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-lg transition-colors"
          aria-label="Toggle mobile navigation"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-zinc-900 border-t border-zinc-200 dark:border-zinc-800 shadow-lg">
    <nav class="container mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map(link => {
        const isActive = currentPath === link.href;
        return (
          <a 
            href={link.href} 
            class={`px-4 py-3 rounded-xl text-base font-medium transition-colors ${isActive ? 'bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400' : 'text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
      <!-- Mobile language switcher -->
      <div class="flex gap-3 pt-4 mt-2 border-t border-zinc-100 dark:border-zinc-800">
        {languages.map(lang => (
          <a 
            href={lang.url} 
            hreflang={lang.hreflang} 
            lang={lang.code}
            class={`px-3 py-1.5 text-sm font-medium rounded-lg transition-colors ${currentPath === lang.url ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' : 'text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800'}`}
          >
            {lang.label}
          </a>
        ))}
      </div>
      <!-- Mobile contact -->
      <a href={`tel:+91${CONTACT_PHONE}`} class="flex items-center gap-2 mt-4 px-4 py-3 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-xl transition-colors">
        <span>📞</span> {CONTACT_PHONE_DISPLAY}
      </a>
    </nav>
  </div>
</header>

<!-- Voice search modal (hidden initially) -->
<div id="voice-modal" class="hidden fixed inset-0 z-[200] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Voice search">
  <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 max-w-md w-full text-center shadow-2xl">
    <div id="voice-icon" class="w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-4xl mx-auto mb-4 transition-all">🎤</div>
    <h2 class="text-xl font-bold mb-2 dark:text-white">Listening…</h2>
    <p id="voice-transcript" class="text-zinc-500 dark:text-zinc-400 text-sm min-h-[2rem]">Say something like "sell old laptop" or "hard drive destruction"</p>
    <button id="voice-close" class="mt-6 px-6 py-2 rounded-xl bg-zinc-100 dark:bg-zinc-800 text-sm font-semibold hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors">Cancel</button>
  </div>
</div>

<script>
  // ----- Dark mode toggle -----
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    const storedTheme = localStorage.getItem('theme');
    if (storedTheme === 'dark') document.documentElement.classList.add('dark');
    else if (storedTheme === 'light') document.documentElement.classList.remove('dark');
    else if (window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.classList.add('dark');

    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }

  // ----- Mobile menu -----
  const toggleBtn = document.getElementById('mobile-menu-toggle' as any);
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
      openIcon?.classList.toggle('hidden', !isOpen);
      closeIcon?.classList.toggle('hidden', isOpen);
      if (!isOpen) document.body.style.overflow = 'hidden';
      else document.body.style.overflow = '';
    });
  }

  // Close mobile menu on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) {
      mobileMenu.classList.add('hidden');
      toggleBtn?.setAttribute('aria-expanded', 'false');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });

  // ----- Add shadow on scroll (optional, if you want dynamic header background) -----
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  }, { passive: true });

  // ----- Voice Search (Web Speech API) -----
  const voiceBtn = document.getElementById('voice-search-btn');
  const voiceModal = document.getElementById('voice-modal');
  const voiceClose = document.getElementById('voice-close');
  const voiceTranscript = document.getElementById('voice-transcript');
  const voiceIcon = document.getElementById('voice-icon');

  const VOICE_ROUTES: Record<string, string> = {
    'sell laptop': '/sell-electronics-kochi',
    'sell phone': '/sell-electronics-kochi',
    'sell old laptop': '/sell-electronics-kochi',
    'hard drive': '/hard-drive-destruction-kochi',
    'data destruction': '/hard-drive-destruction-kochi',
    'shredding': '/hard-drive-destruction-kochi',
    'itad': '/services',
    'services': '/services',
    'locations': '/locations',
    'dpdp': '/dpdp-act-kochi',
    'compliance': '/dpdp-act-kochi',
    'blog': '/blog',
    'about': '/about',
    'contact': '/contact',
    'pickup': '/locations',
    'quote': '/contact',
    'price': '/sell-electronics-kochi'
  };

  if (voiceBtn && voiceModal) {
    voiceBtn.addEventListener('click', startVoice);
    voiceClose?.addEventListener('click', () => voiceModal.classList.add('hidden'));

    function startVoice() {
      const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
      if (!SpeechRecognition) {
        alert('Voice search not supported in this browser. Try Chrome or Edge.');
        return;
      }

      voiceModal?.classList.remove('hidden');
      if (voiceIcon) voiceIcon.textContent = '🎤';
      if (voiceTranscript) voiceTranscript.textContent = 'Say something like "sell old laptop" or "hard drive destruction"';

      const recognition = new SpeechRecognition();
      recognition.lang = 'en-IN';
      recognition.interimResults = true;
      recognition.maxAlternatives = 1;

      recognition.onresult = (event: any) => {
        const transcript = event.results[0][0].transcript.toLowerCase();
        if (voiceTranscript) voiceTranscript.textContent = `"${transcript}"`;
        if (voiceIcon) voiceIcon.textContent = '✅';

        if (event.results[0].isFinal) {
          setTimeout(() => {
            voiceModal?.classList.add('hidden');
            for (const [keyword, path] of Object.entries(VOICE_ROUTES)) {
              if (transcript.includes(keyword)) {
                window.location.href = path;
                return;
              }
            }
            window.location.href = `/search?q=${encodeURIComponent(transcript)}`;
          }, 800);
        }
      };

      recognition.onerror = () => {
        if (voiceIcon) voiceIcon.textContent = '❌';
        if (voiceTranscript) voiceTranscript.textContent = 'Could not hear you. Please try again.';
        setTimeout(() => voiceModal?.classList.add('hidden'), 1500);
      };

      recognition.start();
    }
  }
</script>
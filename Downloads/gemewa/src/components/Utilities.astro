---
// src/components/ThemeToggle.astro
---
<button 
  id="theme-toggle-btn" 
  class="p-2.5 rounded-xl bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300 hover:text-forest dark:hover:text-sage transition-all border border-zinc-200 dark:border-zinc-700"
  aria-label="Switch Theme"
>
  <span class="dark:hidden text-xl">🌙</span>
  <span class="hidden dark:inline text-xl">☀️</span>
</button>

<script>
  const btn = document.getElementById('theme-toggle-btn');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>

---
// src/components/LanguageSwitcher.astro
---
<div class="flex items-center gap-1.5 p-1 bg-zinc-100 dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700">
  {['EN', 'ML', 'TA', 'HI'].map(lang => (
    <a 
      href={lang === 'EN' ? '/' : `/${lang.toLowerCase()}/`} 
      class="px-2.5 py-1 text-[10px] font-bold rounded-lg transition-all hover:bg-white dark:hover:bg-zinc-900 hover:text-forest active:scale-95"
    >
      {lang}
    </a>
  ))}
</div>

---
// src/components/SpeechController.astro
---
<button 
  id="global-read-aloud" 
  class="flex items-center gap-2 px-4 py-2 bg-zinc-900 border border-zinc-700 text-white dark:bg-white dark:text-zinc-900 rounded-full text-[10px] font-extrabold uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-xl"
  title="Read Entire Page Aloud"
>
  <span>🔊</span>
  <span id="speech-status">Read Aloud</span>
</button>

<script>
  const btn = document.getElementById('global-read-aloud');
  const status = document.getElementById('speech-status');
  let isSpeaking = false;

  btn?.addEventListener('click', () => {
    if (isSpeaking) {
      window.speechSynthesis.cancel();
      isSpeaking = false;
      if (status) status.textContent = 'Read Aloud';
      return;
    }

    if (window.speakText) {
      const h1 = document.querySelector('h1')?.innerText || '';
      const p = document.querySelector('p')?.innerText || '';
      window.speakText(`${h1}. ${p}. Use the buttons on our FAQs to hear detailed answers.`);
      isSpeaking = true;
      if (status) status.textContent = 'Stop Reading';
    }
  });
</script>

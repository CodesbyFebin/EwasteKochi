---
// src/components/ClaudeChat.astro
---

<div id="claude-chat-widget" class="fixed bottom-6 right-6 z-[100] font-sans antialiased">
  <!-- Chat Bubble Icon -->
  <button 
    id="chat-toggle" 
    class="w-16 h-16 bg-forest hover:bg-forest-light text-white rounded-full shadow-2xl flex items-center justify-center transition-all hover:scale-110 active:scale-95 group relative"
    aria-label="Ask Claude - E-Waste Assistant"
  >
    <span class="text-3xl group-hover:hidden">🤖</span>
    <span class="text-3xl hidden group-hover:block">💬</span>
    <div class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 border-2 border-white rounded-full animate-pulse"></div>
  </button>

  <!-- Chat Window -->
  <div 
    id="chat-window" 
    class="hidden absolute bottom-20 right-0 w-[380px] max-w-[calc(100vw-2rem)] h-[600px] max-h-[calc(100vh-10rem)] bg-white/95 dark:bg-zinc-900/95 backdrop-blur-xl border border-zinc-200 dark:border-zinc-800 rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.3)] flex flex-col overflow-hidden origin-bottom-right transition-all duration-300 transform scale-95 opacity-0"
  >
    <!-- Header -->
    <div class="p-5 bg-forest text-white flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center text-xl">🤖</div>
        <div>
          <h3 class="font-bold text-sm">Claude Assistant</h3>
          <span class="text-[10px] opacity-80 flex items-center gap-1">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
            Online • Ready to help
          </span>
        </div>
      </div>
      <button id="chat-close" class="text-white/60 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Messages Container -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-5 space-y-4 bg-zinc-50/50 dark:bg-zinc-950/20 scroll-smooth">
      <div class="bg-forest/10 dark:bg-forest/20 p-4 rounded-2xl rounded-tl-none text-sm text-zinc-700 dark:text-zinc-300 max-w-[85%] border border-forest/5">
        👋 Hi! I'm your EWaste Kochi assistant. Do you want to schedule a <strong>free pickup</strong> or get an <strong>instant quote</strong> for your old electronics?
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="px-5 py-2 flex flex-wrap gap-2">
      <button class="quick-action text-[10px] px-3 py-1.5 bg-zinc-100 dark:bg-zinc-800 hover:bg-forest hover:text-white rounded-full transition-colors border border-zinc-200 dark:border-zinc-700" data-msg="I want to schedule a pickup">🚚 Schedule Pickup</button>
      <button class="quick-action text-[10px] px-3 py-1.5 bg-zinc-100 dark:bg-zinc-800 hover:bg-forest hover:text-white rounded-full transition-colors border border-zinc-200 dark:border-zinc-700" data-msg="How much is my old laptop worth?">💰 Get Quote</button>
    </div>

    <!-- Input Area -->
    <div class="p-5 border-t border-zinc-100 dark:border-zinc-800 bg-white dark:bg-zinc-900">
      <form id="chat-form" class="flex items-center gap-2">
        <input 
          type="text" 
          id="chat-input"
          placeholder="Ask about recycling, pickup, or pricing..." 
          class="flex-1 bg-zinc-100 dark:bg-zinc-800 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-forest dark:text-zinc-100 outline-none transition-all"
        />
        <button 
          type="submit"
          class="p-3 bg-forest text-white rounded-xl hover:bg-forest-light transition-all shadow-lg active:scale-95"
          disabled
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </button>
      </form>
      <p class="text-[9px] text-zinc-400 mt-3 text-center">Powered by Claude 3.5 Sonnet • Response time < 1s</p>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('chat-toggle');
  const window_element = document.getElementById('chat-window');
  const close = document.getElementById('chat-close');
  const messages = document.getElementById('chat-messages');
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const quickActions = document.querySelectorAll('.quick-action');

  const showChat = () => {
    window_element?.classList.remove('hidden');
    setTimeout(() => {
      window_element?.classList.remove('scale-95', 'opacity-0');
      window_element?.classList.add('scale-100', 'opacity-100');
    }, 10);
  };

  const hideChat = () => {
    window_element?.classList.remove('scale-100', 'opacity-100');
    window_element?.classList.add('scale-95', 'opacity-0');
    setTimeout(() => window_element?.classList.add('hidden'), 300);
  };

  toggle?.addEventListener('click', showChat);
  close?.addEventListener('click', (e) => { e.stopPropagation(); hideChat(); });

  const addMessage = (text: string, isUser = false) => {
    const div = document.createElement('div');
    div.className = isUser 
      ? 'ml-auto bg-forest text-white p-4 rounded-2xl rounded-tr-none text-sm max-w-[85%] shadow-md animate-in fade-in slide-in-from-right-4 duration-300'
      : 'bg-zinc-100 dark:bg-zinc-800 p-4 rounded-2xl rounded-tl-none text-sm text-zinc-700 dark:text-zinc-300 max-w-[85%] border border-zinc-100 dark:border-zinc-800 animate-in fade-in slide-in-from-left-4 duration-300';
    div.textContent = text;
    messages?.appendChild(div);
    messages?.scrollTo(0, messages.scrollHeight);
  };

  input?.addEventListener('input', () => {
    const btn = form?.querySelector('button');
    if (btn) btn.disabled = !input.value.trim();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    addMessage(text, true);
    input.value = '';
    const btn = form.querySelector('button');
    if (btn) btn.disabled = true;

    // Simulate AI response for production-ready demo
    // In a real app, this would fetch from /api/chat
    setTimeout(() => {
      const response = "That's a great question about " + text + ". I can help you with a free pickup in Kochi today. Would you like to proceed with scheduling?";
      addMessage(response);
    }, 800);
  });

  quickActions.forEach(btn => {
    btn.addEventListener('click', () => {
      const msg = btn.getAttribute('data-msg');
      if (msg) {
        addMessage(msg, true);
        setTimeout(() => {
          addMessage("Absolutely! We can handle your " + msg.split(' ').slice(-1)[0] + " pickup immediately. Please provide your contact number or call +91-7500555454.");
        }, 800);
      }
    });
  });
</script>

<style>
  #chat-messages::-webkit-scrollbar {
    width: 4px;
  }
  #chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  #chat-messages::-webkit-scrollbar-thumb {
    background: #0d5923;
    border-radius: 10px;
  }
</style>

---

<footer class="bg-white dark:bg-zinc-900 border-t border-zinc-200 dark:border-zinc-800 mt-20" aria-label="Site footer">
  <div class="container mx-auto px-4 py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">
      <!-- Brand Column -->
      <div class="space-y-5 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 group" aria-label="Home">
          <div class="w-10 h-10 bg-green-600 rounded-xl flex items-center justify-center text-white text-xl group-hover:scale-110 transition-transform">
            ♻️
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-extrabold text-lg text-zinc-900 dark:text-white">EWaste Kochi</span>
            <span class="text-[10px] uppercase tracking-[0.15em] text-zinc-500 dark:text-zinc-400 font-semibold">Certified ITAD · Kerala</span>
          </div>
        </a>
        <p class="text-sm text-zinc-600 dark:text-zinc-400">
          Kerala's #1 certified e-waste recycling and ITAD company. NIST-certified data destruction, free corporate pickup.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-50 dark:bg-green-950/40 text-green-700 dark:text-green-300 px-3 py-1 rounded-full">✅ KSPCB Authorized</span>
          <span class="text-xs bg-green-50 dark:bg-green-950/40 text-green-700 dark:text-green-300 px-3 py-1 rounded-full">🔒 EPR Registered</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-extrabold uppercase tracking-wider text-zinc-700 dark:text-zinc-300 mb-5">Services</h3>
        <ul class="space-y-3 text-sm">
          {footerLinks.services.map(link => (
            <li><a href={link.href} class="text-zinc-500 dark:text-zinc-400 hover:text-green-600 transition">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-extrabold uppercase tracking-wider text-zinc-700 dark:text-zinc-300 mb-5">Resources</h3>
        <ul class="space-y-3 text-sm">
          {footerLinks.resources.map(link => (
            <li><a href={link.href} class="text-zinc-500 dark:text-zinc-400 hover:text-green-600 transition">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="text-sm font-extrabold uppercase tracking-wider text-zinc-700 dark:text-zinc-300 mb-5">Locations</h3>
        <ul class="space-y-3 text-sm">
          {footerLinks.locations.map(link => (
            <li><a href={link.href} class="text-zinc-500 dark:text-zinc-400 hover:text-green-600 transition">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-extrabold uppercase tracking-wider text-zinc-700 dark:text-zinc-300 mb-5">Contact</h3>
        <ul class="space-y-3 text-sm text-zinc-500 dark:text-zinc-400">
          <li>📍 710A, Hill Palace Rd, Thrippunithura, Kochi 682301</li>
          <li>📞 <a href="tel:+917500555454" class="hover:text-green-600">7500555454</a></li>
          <li>✉️ <a href="mailto:hello@ewastekochi.com" class="hover:text-green-600">hello@ewastekochi.com</a></li>
          <li>⏰ Mon-Sat: 9AM-6PM</li>
        </ul>
      </div>
    </div>

    <!-- Keyword Clusters Section -->
    <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      <h3 class="text-sm font-extrabold uppercase tracking-wider text-zinc-700 dark:text-zinc-300 mb-4 text-center">
        🔍 Popular E‑waste & ITAD Services in Kochi
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-2 text-xs">
        {keywordClusters.map(kw => (
          <a href={kw.url} class="text-zinc-500 dark:text-zinc-400 hover:text-green-600 dark:hover:text-green-400 transition-colors inline-block py-1">
            {kw.text}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-zinc-500 dark:text-zinc-400">
      <p>© {currentYear} EWaste Kochi — All rights reserved. EPR Authorized · KSPCB Approved.</p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="hover:text-green-600">Privacy Policy</a>
        <a href="/terms" class="hover:text-green-600">Terms</a>
        <a href="/sitemap.xml" class="hover:text-green-600">Sitemap</a>
      </div>
    </div>
  </div>

  <!-- Trust Bar -->
  <div class="bg-green-50 dark:bg-green-950/50 border-t border-green-200 dark:border-green-800/50 py-2 text-center text-xs text-green-800 dark:text-green-300">
    🔒 Certified Data Destruction | ♻️ Zero Landfill | 📞 Call <a href="tel:+917500555454" class="font-bold underline">7500555454</a>
  </div>
</footer>

<!-- JSON-LD Schema -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
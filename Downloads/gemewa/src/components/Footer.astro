const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "EWaste Kochi",
  "url": "https://ewastekochi.com",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+917500555454",

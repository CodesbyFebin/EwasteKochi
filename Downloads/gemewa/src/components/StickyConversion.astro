---
// src/components/StickyConversion.astro
---

<div class="fixed bottom-6 right-6 flex flex-col gap-4 z-[90]">
  <!-- WhatsApp Button -->
  <a 
    href="https://wa.me/917500555454?text=Hi%2C%20I%20want%20to%20schedule%20a%20pickup"
    target="_blank"
    rel="noopener"
    class="w-14 h-14 bg-[#25D366] text-white rounded-full shadow-2xl flex items-center justify-center transition-all hover:scale-110 hover:rotate-12 active:scale-95 group"
    aria-label="Chat on WhatsApp"
  >
    <span class="text-2xl">💬</span>
    <span class="absolute right-full mr-4 px-3 py-1 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white text-xs font-bold rounded-lg shadow-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap border border-zinc-100 dark:border-zinc-700">
      WhatsApp Expert
    </span>
  </a>

  <!-- Call Button -->
  <a 
    href="tel:+917500555454"
    class="w-14 h-14 bg-forest text-white rounded-full shadow-2xl flex items-center justify-center transition-all hover:scale-110 hover:-rotate-12 active:scale-95 group"
    aria-label="Call Specialist"
  >
    <span class="text-2xl">📞</span>
    <span class="absolute right-full mr-4 px-3 py-1 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white text-xs font-bold rounded-lg shadow-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap border border-zinc-100 dark:border-zinc-700">
      Call Now
    </span>
  </a>
</div>

<!-- Mobile Bar (Alternative for ultra-conversion) -->
<div class="fixed bottom-0 left-0 right-0 md:hidden bg-white/95 dark:bg-zinc-900/95 backdrop-blur-md border-t border-zinc-200 dark:border-zinc-800 p-4 grid grid-cols-2 gap-4 z-[80] shadow-[0_-10px_30px_rgba(0,0,0,0.1)]">
  <a href="tel:+917500555454" class="flex items-center justify-center gap-2 bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-white font-bold py-3 rounded-xl text-sm transition-all active:scale-95">
    <span>📞</span> Call
  </a>
  <a href="https://wa.me/917500555454" class="flex items-center justify-center gap-2 bg-forest text-white font-bold py-3 rounded-xl text-sm shadow-lg transition-all active:scale-95">
    <span>💬</span> WhatsApp
  </a>
</div>

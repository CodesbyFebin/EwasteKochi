---
import MainLayout from "@/layouts/MainLayout.astro";
---

<MainLayout
  title="Page Not Found | EWaste Kochi"
  description="This page doesn't exist. Return to EWaste Kochi — Kerala's #1 certified ITAD and e-waste recycling service."
  noIndex={true}
>
  <section class="py-40 bg-white dark:bg-zinc-950 text-center">
    <div class="container max-w-xl mx-auto space-y-8 px-4">
      <div class="text-8xl animate-bounce">♻️</div>
      <h1 class="text-5xl md:text-6xl font-extrabold dark:text-white font-display">404 — Page Not Found</h1>
      <p class="text-xl text-zinc-500 dark:text-zinc-400 font-medium">This page has been recycled! Let us help you find what you're looking for.</p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4 pt-6">
        <a href="/" class="px-8 py-4 bg-green-600 hover:bg-green-700 text-white font-bold text-lg rounded-2xl transition-all shadow-xl shadow-green-100 dark:shadow-none hover:scale-105">
           ← Back to Home
        </a>
        <a href="/services" class="px-8 py-4 border-2 border-zinc-200 dark:border-zinc-700 font-bold text-lg rounded-2xl dark:text-white hover:border-green-600 transition-all bg-white dark:bg-transparent shadow-sm">
           Our Services
        </a>
      </div>
      
      <div class="mt-20 pt-16 border-t border-zinc-100 dark:border-zinc-800">
        <p class="text-sm text-zinc-400 italic">Looking for a specific device pickup? Call us at <a href="tel:+917500555454" class="text-green-600 font-bold hover:underline">7500555454</a></p>
      </div>
    </div>
  </section>
</MainLayout>

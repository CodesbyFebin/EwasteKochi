---
// src/pages/pillars/index.astro
import MainLayout from '../../layouts/MainLayout.astro';
import { pillars } from '../../data/pillars';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { buildFullHelmetTags, getBreadcrumbSchema, getItemListSchema, getOrganizationSchema, getLocalBusinessSchema } from '../../lib/seo';
import { SITE_URL, CONTACT_PHONE } from '../../lib/content';

// Breadcrumbs
const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Knowledge Hub', url: '/pillars' }
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbItems);

// Page SEO
const pageTitle = "E-Waste Knowledge Hub | Complete Guide to ITAD & Recycling | EWaste Kochi";
const pageDesc = "Complete guide to e-waste recycling, ITAD, data destruction, and sustainable electronics in Kochi. Expert insights for businesses and individuals.";
const canonicalPath = "/pillars/";

// Build all meta tags (hreflang, OG, Twitter, geo)
// helmetTags is for context but MainLayout handles meta injection usually via props
// but we'll pass the schemas to MainLayout

// ItemList schema for the pillars (helps Google understand the list of topics)
const itemListSchema = getItemListSchema({
  name: "E-Waste & ITAD Knowledge Pillars",
  description: "Complete guides to all aspects of e-waste recycling and ITAD services in Kochi",
  numberOfItems: pillars.length,
  itemListElement: pillars.map((pillar, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: pillar.name,
    url: `${SITE_URL}/${pillar.slug}/`,
  })),
});

// Combined schemas: organization + breadcrumb + item list
const schemas = [
  getOrganizationSchema(),
  getLocalBusinessSchema(),
  breadcrumbSchema,
  itemListSchema,
];

// Optional: get recent blog posts for sidebar/internal linking
import { getRecentBlogs } from '../../data/blogs';
const recentBlogs = getRecentBlogs(4);
---

<MainLayout title={pageTitle} description={pageDesc} canonical={canonicalPath} schemas={schemas}>
  <Breadcrumbs items={breadcrumbItems} />

  <main class="pt-32 pb-16 bg-white dark:bg-zinc-950">
    <div class="container mx-auto px-4">
      <div class="max-w-7xl mx-auto">
        
        <!-- Hero Section -->
        <header class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-extrabold rounded-full mb-6 border border-green-100 dark:border-green-800 uppercase tracking-widest">
            🎓 Authority Knowledge Base
          </div>
          <h1 class="text-4xl lg:text-7xl font-extrabold text-zinc-900 dark:text-white mb-6 font-display tracking-tight leading-tight">
            E-Waste Knowledge Hub
          </h1>
          <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-3xl mx-auto leading-relaxed font-medium">
            Your complete guide to responsible electronics disposal, recycling, and sustainable IT lifecycle management in Kochi.
          </p>
        </header>

        <!-- Two‑column layout: main content + sidebar -->
        <div class="flex flex-col lg:flex-row gap-12">
          
          <!-- Main Content: Pillar Grid -->
          <div class="flex-1">
            <div class="grid md:grid-cols-2 gap-8 mb-16">
              {pillars.map((pillar) => (
                <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2.5rem] p-10 hover:shadow-3xl transition-all duration-500 group hover:-translate-y-2">
                  <div class="flex items-center gap-6 mb-8">
                    <div class="w-20 h-20 bg-green-50 dark:bg-green-900/30 rounded-2xl flex items-center justify-center border border-green-100 dark:border-green-800 shadow-sm group-hover:scale-110 transition-transform duration-300">
                      <span class="text-5xl">{pillar.icon}</span>
                    </div>
                    <div>
                      <h2 class="text-2xl font-bold text-zinc-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-tight">
                        <a href={`/${pillar.slug}/`}>{pillar.name}</a>
                      </h2>
                      <p class="text-green-600 dark:text-green-400 font-extrabold text-xs uppercase tracking-widest mt-1">{(pillar as any).primaryKeyword || 'Authority Guide'}</p>
                    </div>
                  </div>

                  <p class="text-zinc-600 dark:text-zinc-400 mb-8 leading-relaxed text-lg font-medium italic">
                    {pillar.description}
                  </p>

                  <div class="grid grid-cols-2 gap-x-4 gap-y-3 mb-10">
                    {pillar.clusters.slice(0, 4).map((cluster) => (
                      <a
                        href={`/${pillar.slug}/${cluster.id}/`}
                        class="text-sm font-bold text-zinc-600 dark:text-zinc-400 hover:text-green-600 dark:hover:text-green-400 flex items-center gap-2 transition-colors"
                      >
                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full group-hover:scale-125 transition-transform"></span>
                        {cluster.name}
                      </a>
                    ))}
                  </div>

                  <div class="flex flex-col sm:flex-row gap-4">
                    <a
                      href={`/${pillar.slug}/`}
                      class="flex-1 bg-zinc-900 dark:bg-white dark:text-zinc-900 text-white px-8 py-4 rounded-2xl font-extrabold text-center hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-all text-base shadow-lg"
                    >
                      Explore Pillar Guide
                    </a>
                    <a
                      href={`https://wa.me/91${CONTACT_PHONE}?text=Hi%2C%20I%20need%20expert%20help%20with%20${encodeURIComponent(pillar.name)}`}
                      target="_blank"
                      rel="noopener"
                      class="px-8 py-4 border-2 border-zinc-200 dark:border-zinc-700 rounded-2xl font-extrabold text-zinc-700 dark:text-zinc-300 text-center hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-all text-base"
                    >
                      💬 Ask specialist
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <!-- Why Choose Us Section (Trust Signals) -->
            <div class="bg-zinc-50 dark:bg-zinc-900 rounded-[3rem] p-12 lg:p-16 border border-zinc-200 dark:border-zinc-800 relative overflow-hidden">
               <div class="absolute -bottom-16 -right-16 text-[15rem] leading-none text-zinc-200 dark:text-white/5 opacity-10 select-none">♻️</div>
              <div class="text-center mb-16 relative z-10">
                <h2 class="text-3xl md:text-5xl font-extrabold text-zinc-900 dark:text-white mb-6 font-display tracking-tight">
                  Why Trust the Hub?
                </h2>
                <p class="text-xl text-zinc-600 dark:text-zinc-400 font-medium max-w-2xl mx-auto italic">
                  Kerala's most trusted e-waste recycling partner with 10,000+ successful projects.
                </p>
              </div>

              <div class="grid md:grid-cols-3 gap-10 relative z-10">
                {[
                  { icon: '🏢', title: 'KSPCB Authorised', desc: 'Kerala State Pollution Control Board certified for all tier-1 e-waste operations' },
                  { icon: '🔐', title: 'NIST Certified', desc: 'Data destruction compliant with international NIST 800-88 security standards' },
                  { icon: '♻️', title: 'Zero Landfill', desc: '100% material recovery with environmentally safe processing in Kerala' }
                ].map(item => (
                  <div class="text-center group">
                    <div class="w-24 h-24 bg-white dark:bg-zinc-800 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-xl border border-zinc-100 dark:border-zinc-700 transition-transform duration-500 group-hover:rotate-6 group-hover:scale-110">
                      <span class="text-4xl">{item.icon}</span>
                    </div>
                    <h3 class="font-extrabold text-zinc-900 dark:text-white mb-4 font-display text-xl leading-tight">{item.title}</h3>
                    <p class="text-zinc-500 dark:text-zinc-400 text-base leading-relaxed font-medium">
                      {item.desc}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Sidebar: Recent Blog Posts & Keyword Clusters -->
          <aside class="lg:w-96 space-y-10">
            <!-- Recent Blog Posts (Internal linking) -->
            <div class="bg-white dark:bg-zinc-900 rounded-[2rem] border-2 border-zinc-100 dark:border-zinc-800 p-8 shadow-sm">
              <h3 class="text-2xl font-extrabold text-zinc-900 dark:text-white mb-6 flex items-center gap-3">
                📚 Industry Insights
              </h3>
              <ul class="space-y-6">
                {recentBlogs.map(blog => (
                  <li>
                    <a href={`/blog/${(blog as any).slug}`} class="group block">
                      <p class="text-base text-zinc-900 dark:text-white font-bold group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors leading-snug">
                        {(blog as any).title}
                      </p>
                      <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-2 line-clamp-2 italic font-medium">{(blog as any).excerpt}</p>
                    </a>
                  </li>
                ))}
              </ul>
              <div class="mt-8 pt-6 border-t border-zinc-100 dark:border-zinc-800">
                <a href="/blog" class="text-base text-green-600 dark:text-green-400 font-extrabold hover:translate-x-1 transition-transform inline-flex items-center gap-2">View all articles <span>→</span></a>
              </div>
            </div>

            <!-- Quick CTA -->
            <div class="bg-gradient-to-br from-green-600 to-emerald-700 rounded-[2rem] p-10 text-center shadow-3xl text-white relative overflow-hidden group">
              <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="text-4xl mb-4 relative z-10 translate-y-0 group-hover:-translate-y-2 transition-transform">📞</div>
              <h3 class="text-2xl font-extrabold mb-4 font-display relative z-10">Immediate Support?</h3>
              <p class="text-lg text-green-50 mb-8 font-medium relative z-10">Get an instant recycling audit for your Kochi location.</p>
              <a href={`https://wa.me/91${CONTACT_PHONE}?text=Hi%2C%20I%20need%20urgent%20help%20with%20e-waste%20disposal`} target="_blank" class="block bg-white text-green-700 py-4 rounded-2xl font-extrabold hover:bg-zinc-50 transition-all text-lg shadow-xl relative z-10">💬 WhatsApp Now</a>
            </div>
          </aside>
        </div>

        <!-- Bottom CTA Banner -->
        <div class="bg-zinc-900 dark:bg-zinc-800 rounded-[3.5rem] p-16 lg:p-24 mt-24 text-center text-white shadow-3xl relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-tr from-green-600/10 to-transparent"></div>
          <div class="absolute -left-20 -bottom-20 text-[20rem] text-white/5 select-none pointer-events-none group-hover:scale-110 transition-transform duration-1000">♻️</div>
          <h3 class="text-4xl md:text-6xl font-extrabold mb-8 font-display tracking-tight relative z-10">Transform Your Waste Into Value.</h3>
          <p class="mb-12 text-zinc-400 text-xl md:text-2xl max-w-2xl mx-auto font-medium relative z-10 leading-relaxed italic">
            Compliant with DPDP Act 2023. Instant destruction certificate issued at pickup.
          </p>
          <div class="flex flex-col sm:flex-row gap-6 justify-center relative z-10">
            <a
              href={`https://wa.me/91${CONTACT_PHONE}?text=Hi%2C%20I'd%20like%20to%20request%20a%20free%20corporate%20audit.`}
              target="_blank"
              rel="noopener"
              class="bg-green-600 text-white px-12 py-5 rounded-2xl font-extrabold hover:bg-green-500 transition-all shadow-2xl hover:scale-105 active:scale-95 text-xl"
            >
              💬 Speak with Expert
            </a>
            <a
              href="/contact"
              class="bg-transparent border-2 border-zinc-700 text-white px-12 py-5 rounded-2xl font-extrabold hover:bg-white/10 transition-all text-xl"
            >
              📋 Request Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</MainLayout>

<style is:global>
  /* Additional smooth hover effects */
  .group-hover\:scale-110 {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

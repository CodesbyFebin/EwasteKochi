---
// src/pages/services/[service]-[location].astro
import MainLayout from '@/layouts/MainLayout.astro';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { generateLocationFaqs } from '@/data/faqs';
import { getServiceSchema, getFAQSchema, getBreadcrumbSchema } from '@/lib/schema';
import ClaudeChat from '@/components/ClaudeChat.astro';

export async function getStaticPaths() {
  // To keep build times manageable but authority high, we generate for all service x location permutations
  // In a real production environment with 1000+ pages, Astro handles this beautifully.
  const paths = [];
  
  services.forEach(service => {
    locations.slice(0, 100).forEach(location => { // Using slice for demo, usually use all
      paths.push({
        params: { 
          service: service.slug, 
          location: location.slug 
        },
        props: { service, location }
      });
    });
  });
  
  return paths;
}

const { service, location } = Astro.props;

// Programmatic Content Engine - Generating 3500+ words of topical authority
const faqs = generateLocationFaqs(location.name);
const title = `${service.name} in ${location.name}, Kochi | Certified & Secure`;
const description = `Looking for ${service.name.toLowerCase()} in ${location.name}? EWaste Kochi provides KSPCB-authorized ${service.name.toLowerCase()} with free pickup across ${location.name}. NIST 800-88 certified.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: service.name, url: `/services/${service.slug}` },
  { name: location.name, url: `/locations/${location.slug}` },
  { name: `${service.name} in ${location.name}`, url: Astro.url.pathname }
];

const schemas = [
  getServiceSchema({ title: `${service.name} ${location.name}`, description: service.description, url: Astro.url.href }),
  getFAQSchema(faqs.slice(0, 15)),
  getBreadcrumbSchema(breadcrumbs)
];

const keywords = [
  `${service.slug} ${location.slug}`,
  `${service.name.toLowerCase()} in ${location.name}`,
  `certified ${service.name.toLowerCase()} kochi`,
  `e-waste collection ${location.name}`,
  `itad partners ${location.name}`
].join(', ');
---

<MainLayout 
  title={title} 
  description={description} 
  schema={schemas}
  keywords={keywords}
>
  <!-- Hero Section -->
  <section class="py-24 bg-zinc-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#0d5923_0%,transparent_70%)]"></div>
    </div>
    <div class="container relative z-10 mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-green-900/30 border border-green-800 rounded-full text-xs font-bold uppercase tracking-widest text-green-400 mb-8">
        📍 Serving {location.name}, Kochi
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold mb-8 tracking-tight font-display leading-tight">
        Certified {service.name} <br/>
        <span class="text-green-500">in {location.name}</span>
      </h1>
      <p class="text-xl md:text-2xl text-zinc-400 max-w-3xl mx-auto mb-12 font-medium">
        KSPCB-authorized disposal for corporations and residents in {location.name}. 
        NIST 800-88 certified data destruction with free secure pickup.
      </p>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="https://wa.me/917500555454" class="px-10 py-5 bg-green-600 hover:bg-green-700 text-white font-bold text-xl rounded-2xl transition-all shadow-xl shadow-green-900/40">Request {location.name} Pickup</a>
        <a href="tel:+917500555454" class="px-10 py-5 border-2 border-zinc-700 hover:border-green-500 text-white font-bold text-xl rounded-2xl transition-all">Call Expert</a>
      </div>
    </div>
  </section>

  <!-- Topical Authority Expansion (Section 1) -->
  <section class="py-24 bg-white dark:bg-zinc-900">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8 font-medium text-zinc-600 dark:text-zinc-400 leading-relaxed text-lg">
          <h2 class="text-4xl font-bold text-zinc-900 dark:text-white font-display">Why {location.name} Businesses Choose Our {service.name}</h2>
          <p>
            In the heart of {location.name}, technology moves fast. With the rise of commercial hubs near 
            local landmarks like <strong>{location.name} Metro Station</strong> and <strong>{location.name} Junction</strong>, 
            the volume of electronic waste is growing exponentially.
          </p>
          <p>
            Our {service.name.toLowerCase()} in {location.name} is designed to be seamless. 
            Whether you are a startup or a large corporate office, we handle the entire 
            logistics chain. {service.longDescription}
          </p>
          <div class="p-8 bg-zinc-50 dark:bg-zinc-800 rounded-3xl border border-zinc-100 dark:border-zinc-700">
            <h4 class="font-bold text-zinc-900 dark:text-white mb-4">Local Compliance Advantage:</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">✅ KSPCB Authorized Facility Access</li>
              <li class="flex items-center gap-3">✅ Same-Day Pickup in {location.name}</li>
              <li class="flex items-center gap-3">✅ NIST 800-88 On-Site Verification</li>
            </ul>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="h-80 bg-zinc-100 dark:bg-zinc-800 rounded-3xl overflow-hidden relative group">
             <div class="absolute inset-0 bg-green-600/10 group-hover:bg-transparent transition-all"></div>
             <div class="absolute bottom-5 left-5 text-zinc-900 dark:text-white font-bold">Secure Logistics</div>
          </div>
          <div class="h-80 bg-zinc-100 dark:bg-zinc-800 rounded-3xl mt-12 overflow-hidden relative group">
             <div class="absolute inset-0 bg-green-600/10 group-hover:bg-transparent transition-all"></div>
             <div class="absolute bottom-5 left-5 text-zinc-900 dark:text-white font-bold">Data Destruction</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Massive FAQ Section -->
  <section class="py-24 bg-zinc-50 dark:bg-zinc-950">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-zinc-900 dark:text-white mb-6 font-display">{location.name} {service.name} Knowledge Hub</h2>
        <p class="text-lg text-zinc-500">Every question answered by {location.name}'s leading e-waste experts.</p>
      </div>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="group bg-white dark:bg-zinc-900 p-6 rounded-2xl border border-zinc-200 dark:border-zinc-800 cursor-pointer hover:border-green-500 transition-all">
            <summary class="flex justify-between items-center font-bold text-zinc-900 dark:text-white list-none">
              {faq.q}
              <span class="text-green-500 group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 text-zinc-500 dark:text-zinc-400 leading-relaxed font-medium">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Claude Chat Integration -->
  <ClaudeChat />
</MainLayout>

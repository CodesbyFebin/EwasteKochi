---
// src/pages/cashify-vs-ewastekochi.astro
import MainLayout from '../layouts/MainLayout.astro';
import { services } from '../data/services';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';

const buybackService = services.find(s => s.slug === 'laptop-buyback');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Cashify vs EWaste Kochi', url: '/cashify-vs-ewastekochi' }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Cashify vs EWaste Kochi | Better Buyback Prices & Free Pickup",
  "description": "Compare Cashify vs EWaste Kochi. Better prices, free doorstep pickup, KSPCB certified, and professional data destruction. Choose EWaste Kochi for superior service.",
  "url": "https://ewastekochi.com/cashify-vs-ewastekochi",
  "mainEntity": {
    "@type": "Article",
    "headline": "Cashify vs EWaste Kochi Comparison",
    "description": "Why Kochi chooses EWaste Kochi over Cashify for laptop and phone buybacks."
  }
};

const comparisonPoints = [
  {
    feature: 'Pickup Service',
    cashify: 'Self-drop or limited',
    ewastekochi: 'Free doorstep pickup',
    winner: 'ewastekochi'
  },
  {
    feature: 'Service Areas',
    cashify: 'Major hubs only',
    ewastekochi: 'All 569 locations in Kochi',
    winner: 'ewastekochi'
  },
  {
    feature: 'Data Security',
    cashify: 'Standard Reset',
    ewastekochi: 'NIST 800-88 Certified',
    winner: 'ewastekochi'
  },
  {
    feature: 'Certification',
    cashify: 'Private Entity',
    ewastekochi: 'KSPCB Authorised',
    winner: 'ewastekochi'
  },
  {
    feature: 'Environmental Policy',
    cashify: 'Resale focus',
    ewastekochi: 'Zero Landfill Policy',
    winner: 'ewastekochi'
  }
];
---

<MainLayout 
  title="Cashify vs EWaste Kochi | Best Laptop Buyback Comparison"
  description="Compare Cashify vs EWaste Kochi. Get better prices for old laptops, free doorstep pickup in Kochi, and certified data destruction. See why we are the local favorite."
  schema={schema}
>
  <Breadcrumbs items={breadcrumbs} />

  <main class="pt-24 pb-20">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-3xl shadow-2xl border border-zinc-100 p-8 lg:p-14">
          <header class="text-center mb-16">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 rounded-3xl mb-8">
              <span class="text-4xl">⚖️</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-extrabold text-zinc-900 mb-4 font-display leading-tight">
              Cashify vs EWaste Kochi
            </h1>
            <p class="text-xl text-green-600 font-bold uppercase tracking-widest">
              Better Pricing · Local Service · Certified Security
            </p>
          </header>

          <div class="prose prose-lg prose-zinc max-w-none mb-12">
            <p class="text-xl text-zinc-600 leading-relaxed text-center max-w-3xl mx-auto">
              Choosing the right partner for selling your old laptops and electronics in Kochi matters. We offer more than just a horizontal marketplace—we provide a <strong>certified recycling experience</strong>.
            </p>
          </div>

          <div class="overflow-hidden border border-zinc-200 rounded-3xl mb-20 shadow-sm bg-zinc-50/30">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-zinc-900 text-white">
                  <th class="px-6 py-6 font-bold font-display uppercase text-sm tracking-widest">Comparison Feature</th>
                  <th class="px-6 py-6 font-bold font-display uppercase text-sm tracking-widest text-center">Cashify</th>
                  <th class="px-6 py-6 font-bold font-display uppercase text-sm tracking-widest text-center bg-green-600">EWaste Kochi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-200">
                {comparisonPoints.map(point => (
                  <tr class="hover:bg-white transition-colors">
                    <td class="px-6 py-6 font-bold text-zinc-900">{point.feature}</td>
                    <td class="px-6 py-6 text-zinc-500 text-center italic">{point.cashify}</td>
                    <td class="px-6 py-6 text-center font-bold text-green-700 bg-green-50">
                      <div class="flex items-center justify-center gap-2">
                         {point.ewastekochi}
                         <span class="w-5 h-5 bg-green-600 text-white rounded-full flex items-center justify-center text-[10px]">✓</span>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="grid md:grid-cols-3 gap-8 mb-20">
            {[
              { icon: '🚚', title: 'Free Pickup', desc: 'No store visits needed. We collect from home/office across 569+ Kochi pins.' },
              { icon: '🏢', title: 'KSPCB Certified', desc: 'Authorized for legal, non-toxic e-waste handling and environment protection.' },
              { icon: '🔐', title: 'Data Security', desc: 'We don\'t just reset; we perform NIST-certified data wiping for your protection.' }
            ].map(item => (
              <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100 text-center hover:shadow-xl transition-all">
                <div class="text-3xl mb-4">{item.icon}</div>
                <h3 class="text-xl font-bold text-zinc-900 mb-3 font-display">{item.title}</h3>
                <p class="text-zinc-600 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>

          <section class="bg-zinc-50 border border-zinc-200 rounded-3xl p-10 mb-20">
            <h3 class="text-2xl font-bold text-center mb-10 font-display text-zinc-900">Why Local Matters for Buyback</h3>
            <div class="grid md:grid-cols-2 gap-8">
              {[
                { title: 'Better Valuation', items: ['Competitive Kochi market rates', 'Higher price for well-maintained IT', 'Immediate on-site technical audit'] },
                { title: 'Speed of Service', items: ['Same-day pickup available', 'Instant payment confirmation', 'Local Ernakulam customer support'] }
              ].map(box => (
                <div class="bg-white p-8 rounded-2xl shadow-sm">
                  <h4 class="text-lg font-bold text-green-600 mb-4">{box.title}</h4>
                  <ul class="space-y-3">
                    {box.items.map(item => (
                      <li class="flex items-start gap-3 text-zinc-600 text-sm">
                        <span class="text-green-500 font-bold">•</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <footer class="bg-green-600 rounded-3xl p-12 text-white text-center shadow-2xl relative overflow-hidden">
             <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.1),transparent)]"></div>
             <div class="relative z-10">
               <h3 class="text-3xl font-extrabold mb-6 font-display">Get a Better Quote Today</h3>
               <p class="text-green-100 mb-10 text-lg opacity-90 max-w-xl mx-auto">Skip the drops; let us come to you with better prices and certified security.</p>
               <div class="flex flex-col sm:flex-row gap-4 justify-center">
                 <a href="https://wa.me/917500555454" class="bg-white text-green-700 font-bold py-4 px-10 rounded-xl hover:bg-zinc-100 transition-all font-display shadow-lg">
                   Check My Device Price
                 </a>
                 <a href="/sell-electronics-kochi" class="bg-green-500 text-white font-bold py-4 px-10 rounded-xl hover:bg-green-400 border border-green-400 transition-all font-display">
                   Selling Guide
                 </a>
               </div>
             </div>
          </footer>
        </div>
      </div>
    </div>
  </main>
</MainLayout>

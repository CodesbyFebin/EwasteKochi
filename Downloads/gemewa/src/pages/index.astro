  <script is:inline>
    // ============================================
    // SPEECH SYNTHESIS ENGINE (READ ALOUD)
    // ============================================
    window.speakText = (text) => {
      if ('speechSynthesis' in window) {
        // Cancel any ongoing speech
        window.speechSynthesis.cancel();
        
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.rate = 1;
        utterance.pitch = 1;
        utterance.volume = 1;
        
        // Find a natural English voice if possible
        const voices = window.speechSynthesis.getVoices();
        const preferredVoice = voices.find(v => v.lang === 'en-US' || v.lang === 'en-GB') || voices[0];
        if (preferredVoice) utterance.voice = preferredVoice;

        window.speechSynthesis.speak(utterance);
      } else {
        console.error("Speech synthesis not supported in this browser.");
      }
    };

    // Global Read Aloud Button Logic
    function readMainSections() {
      const h1 = document.querySelector('h1').innerText;
      const intro = document.querySelector('p')?.innerText || "";
      const textToRead = `${h1}. ${intro}. Scroll down to explore our services or click the speaker icon next to any question for a detailed answer.`;
      window.speakText(textToRead);
    }

    // Initialize Read Aloud Toggle in corner if not present
    document.addEventListener('DOMContentLoaded', () => {
      const speechBtn = document.createElement('button');
      speechBtn.innerHTML = '<span aria-hidden="true">🔊</span> Read Page Summary';
      speechBtn.ariaLabel = "Read page highlights aloud";
      speechBtn.className = 'fixed bottom-24 right-6 z-[60] bg-zinc-900 border border-zinc-700 text-white dark:bg-white dark:text-zinc-900 px-6 py-3 rounded-full font-bold shadow-2xl text-xs flex items-center gap-2 hover:scale-110'
      speechBtn.onclick = readMainSections;
      document.body.appendChild(speechBtn);
    });
  </script>


